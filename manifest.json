{
  "manifest_version": 3,
  "name": "Blip",
  "version": "0.1.0",
  "description": "True edit-in-place for flat-file websites. Edit your live site, commit to GitHub.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_title": "Toggle Blip"
  },
  "host_permissions": [
    "https://api.github.com/*",
    "https://api.groq.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "config.js",
        "github.js",
        "file-resolver.js",
        "mapping.js",
        "edit-history.js",
        "llm.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar.html",
        "sidebar.js",
        "sidebar.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}